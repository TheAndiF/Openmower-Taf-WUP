WAHA_EXTERNAL_PORT=9629
WAHA_DASHBOARD_ENABLED=true
WAHA_DASHBOARD_USERNAME=waha
WAHA_DASHBOARD_PASSWORD=replace_with_your_dashboard_password
WAHA_API_KEY=replace_with_your_waha_api_key

# Preferred WAHA session for this OpenMower installation.
# Must match the session name shown by /api/sessions, e.g. Wasserleberweg.
WAHA_SESSION=Wasserleberweg

# WAHA session self-healing in the MQTT controller.
# The controller checks the selected session and calls /start or /restart via
# the WAHA API when the session is STOPPED, FAILED or stuck on STARTING.
WAHA_AUTO_REPAIR_SESSION=true
WAHA_START_STOPPED_SESSION=true
WAHA_STARTING_TIMEOUT_SECONDS=90
WAHA_REPAIR_COOLDOWN_SECONDS=300
WAHA_MAX_RESTARTS_PER_HOUR=3
WAHA_SEND_READY_WAIT_SECONDS=30
WAHA_WATCHDOG_SECONDS=60

# Optional human-readable dashboard URL published under messenger/status/description.
# Replace <openmower-ip> with the IP or hostname you use in your browser.
WAHA_DASHBOARD_URL=http://<openmower-ip>:9629/dashboard
CREDENTIALS_FILE_HINT=/opt/stacks/whatsapp/.env

MQTT_HOST=Mosquitto
MQTT_PORT=1883
MQTT_BASE_TOPIC=messenger

WAHA_URL=http://waha:3000
CONTROLLER_REFRESH_SECONDS=60
BOT_HTTP_PORT=8080

MESSENGER_PROVIDER=waha
MESSENGER_PROTOCOL=whatsapp
BOT_COMMANDS_FILE=/data/bot_commands.xml

# Status cache sources for Mobert: Status. Use the /data topic for WiFi;
# the sibling /bson topic is binary and must not be cached as text.
OPENMOWER_STATUS_CACHE_TOPICS=robot_state/json,gps_state/json,gps/position/json,gps_position/json,area_queue/json,mow_area/json,mow_area/status/json,mowing_area/json,mowing/area_queue/json,map/mowing_progress/status/json,mowing_progress/status/json,sensors/om_system_wifi_signal_percent/data,openmower/robot_state/json,openmower/gps_state/json,openmower/gps/position/json,openmower/gps_position/json,openmower/area_queue/json,openmower/mow_area/json,openmower/mow_area/status/json,openmower/mowing_area/json,openmower/mowing/area_queue/json,openmower/map/mowing_progress/status/json,openmower/mowing_progress/status/json,openmower/sensors/om_system_wifi_signal_percent/data

# Time zone used for human-readable Mobert status replies.
STATUS_TIMEZONE=Europe/Berlin
